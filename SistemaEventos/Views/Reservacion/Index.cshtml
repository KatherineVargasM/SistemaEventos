@model IEnumerable<SistemaEventos.Models.Reservacion>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.EventoId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Evento)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ClienteId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cliente)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaReservacion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.EventoId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Evento)
            </td>
            <td>
                @Html.DisplayFor(model => item.ClienteId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Cliente)
            </td>
            <td>
                @Html.DisplayFor(model => item.FechaReservacion)
            </td>
            <td>
                @Html.DisplayFor(model => item.Estado)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ReservacionId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ReservacionId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ReservacionId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
